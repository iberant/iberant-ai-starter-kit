# Vite / React — environment variables
#
# Copy to `.env` (or `.env.local` for personal overrides — both are gitignored).
# IMPORTANT: only variables prefixed with VITE_ are exposed to client code, and
# everything you expose is bundled into the browser. NEVER put real secrets here.
# Keep secrets on the server (ASP.NET Core) and call it from the client.

VITE_API_BASE_URL=https://localhost:5001
VITE_APP_NAME=My App
VITE_ENABLE_ANALYTICS=false
