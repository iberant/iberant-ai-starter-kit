{
  "name": "app-frontend",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint . && prettier --check .",
    "format": "prettier --write .",
    "test": "vitest"
  },
  "devDependencies": {
    "eslint": "^9.0.0",
    "prettier": "^3.3.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.0",
    "vitest": "^2.0.0"
  },
  "prettier": {
    "printWidth": 120,
    "semi": true,
    "bracketSameLine": true,
    "useTabs": false,
    "tabWidth": 2,
    "trailingComma": "none",
    "singleQuote": true,
    "bracketSpacing": true
  }
}
